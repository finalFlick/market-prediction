# Copy to .env and fill in. NEVER commit .env.

# Binance (use testnet keys until graduating to live)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Coinbase Advanced Trade
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_SANDBOX=true

# Storage
DATA_DIR=./data
DUCKDB_PATH=./data/market.duckdb

# Redis (pub/sub between engine and backend)
REDIS_URL=redis://redis:6379/0

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (Next.js + NextAuth)
NEXT_PUBLIC_API_URL=http://backend:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Operator API (backend kill-switch / mutating routes; MVP-0)
OPERATOR_API_KEY=

# Hermes (optional, trading-net)
HERMES_URL=

# Local LLM (Ollama)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# Runtime
LOG_LEVEL=INFO
ENV=dev
