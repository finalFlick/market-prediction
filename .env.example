# Copy to .env and fill in. NEVER commit .env.

# Binance (use testnet keys until graduating to live)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Coinbase Advanced Trade
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_SANDBOX=true

# Storage
DATA_DIR=./data
DUCKDB_PATH=./data/market.duckdb

# Redis (pub/sub between engine and backend)
REDIS_URL=redis://redis:6379/0

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://backend:8000

# Local LLM (Ollama)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# Runtime
LOG_LEVEL=INFO
ENV=dev
