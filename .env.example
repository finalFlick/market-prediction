# Copy to .env and fill in. NEVER commit .env.

# Binance — only for live/testnet trading or CCXT; NOT needed for public REST ingest
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Optional: if api.binance.com returns HTTP 451 (region), try e.g. https://api.binance.us
# BINANCE_PUBLIC_REST_BASE=https://api.binance.com

# Coinbase Advanced Trade — only for keyed API; NOT needed for public candle ingest
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_SANDBOX=true

# Storage (DuckDB = single embedded file, no server)
DATA_DIR=./data
DUCKDB_PATH=./data/market.duckdb

# Redis — optional outside Docker (omit to use in-memory bus + DuckDB outbox; health still ok)
REDIS_URL=redis://redis:6379/0

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (Next.js + NextAuth)
NEXT_PUBLIC_API_URL=http://backend:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Operator API (backend kill-switch / mutating routes; MVP-0)
OPERATOR_API_KEY=

# Hermes — optional internal helper; unused in MVP-0
HERMES_URL=

# Local LLM (Ollama)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# Runtime
LOG_LEVEL=INFO
ENV=dev
